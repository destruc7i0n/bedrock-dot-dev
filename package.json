{
  "name": "bedrock-dev",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run build:prepare && pnpm run build:astro",
    "build:prepare": "pnpm run generate-docs-file && pnpm run generate-sitemap",
    "build:astro": "astro build",
    "start": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "generate-sitemap": "tsx scripts/generate-sitemap.ts",
    "generate-docs-file": "tsx scripts/generate-docs-manifest.ts",
    "generate-vercel-redirects": "tsx scripts/generate-vercel-redirects.ts",
    "type-check": "tsc --noEmit",
    "postinstall": "git submodule update --recursive --remote"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^10.0.0",
    "@aws-sdk/client-s3": "^3.758.0",
    "@docsearch/css": "^3.9.0",
    "@docsearch/react": "^3.9.0",
    "@heroicons/react": "^2.2.0",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/react": "^1.0.1",
    "@vercel/og": "^0.11.1",
    "astro": "^6.0.4",
    "clsx": "^2.1.1",
    "flat-cache": "^6.1.20",
    "i18next": "^25.8.18",
    "nanostores": "^1.2.0",
    "nprogress": "^0.2.0",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.8",
    "sass": "^1.98.0",
    "sitemap": "^9.0.1",
    "tailwind-merge": "2.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/forms": "^0.5.11",
    "@types/flat-cache": "^2.0.2",
    "@types/node": "^25.5.0",
    "@types/nprogress": "^0.2.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "isomorphic-unfetch": "^4.0.2",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "license": "GPL-3.0"
}
